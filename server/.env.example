# AI Teaching System - Server Environment Configuration
# Copy this file to .env and fill in your values

# --- Server ---
DEBUG=true

# --- Ollama (local LLM) ---
OLLAMA__BASE_URL=http://localhost:11434
OLLAMA__DEFAULT_MODEL=qwen2.5:7b
